WIX_MOCK_MODE=true
WIX_CLIENT_ID=your-wix-app-id-here
WIX_CLIENT_SECRET=your-wix-app-secret-here
WIX_SCOPES=offline_access bookings.read services.read
WIX_TOKEN_URL=https://www.wixapis.com/oauth2/token
WIX_API_BASE=https://www.wixapis.com

APP_DB_PATH=trail_planner.db
APP_ENCRYPTION_SECRET=change-this-to-a-random-secret-in-production
APP_SECRET=dev-secret-change-me
AUTH_RETURN_MAGIC_LINK=true
FRONTEND_BASE_URL=http://localhost:3000

GOOGLE_API_KEY=
ORS_API_KEY=
HERE_API_KEY=
EE_SERVICE_ACCOUNT_EMAIL=
EE_PRIVATE_KEY_PATH=
CLC_WMS_URL=
CLC_WMS_LAYER=
EPFD_COLLECTION_ID=

SALONIC_ENABLED=true
SALONIC_API_BASE=https://salonic.hu
SALONIC_DEFAULT_ADDRESS=Budapest
SALONIC_RADIUS_KM=20
SALONIC_MAX_LOCATIONS=25
# Comma-separated location type IDs: 10=Masszázsszalon, 11=Gyanta szalon, 12=Alakformáló stúdió, 8=Szépségszalon, 6=Manikűr/Pedikűr, 1=Szépségszalon, 2=Fodrászat, 3=Barbershop, 4=Szalonok
SALONIC_LOCATION_TYPE_IDS=10,11,12,8,6,1,2,3,4
# Comma-separated service category IDs: 1=Arckezelés, 4=Hajvágás, 8=Szakáll, 12=Manikűr, 13=Pedikűr, 20=Masszázs, 21=Gyantázás
SALONIC_SERVICE_CATEGORY_IDS=1,4,8,12,13,20,21
# Optional service type ID filter
SALONIC_SERVICE_TYPE_ID=

# Booked4Us integration (real free slot checks from /api/Calendars/{id}/AllIntervals)
BOOKED4US_ENABLED=false
BOOKED4US_API_BASE=https://demo.booked4.us/rest-v2
BOOKED4US_USERNAME=
BOOKED4US_PASSWORD=
BOOKED4US_MAX_CALENDARS=20
